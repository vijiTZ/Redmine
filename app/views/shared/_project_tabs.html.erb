<%#
  Reusable global dashboard tab strip.
  Pass `active` local: 'projects' | 'activity' | 'issues' | 'timelog'
  Usage: render 'shared/project_tabs', active: 'issues'
%>
<% active_tab = local_assigns[:active] || '' %>
<div class="tz-gtab__wrap">
  <div class="tz-gtab">
    <%= link_to l(:label_project_plural), projects_path,
          class: "tz-gtab__item #{active_tab == 'projects' ? 'tz-gtab__item--active' : ''}" %>

    <%= link_to l(:label_activity), activity_path,
          class: "tz-gtab__item #{active_tab == 'activity' ? 'tz-gtab__item--active' : ''}" %>

    <% if User.current.logged? %>
      <%= link_to l(:label_issue_plural), issues_path,
            class: "tz-gtab__item #{active_tab == 'issues' ? 'tz-gtab__item--active' : ''}" %>

      <%= link_to l(:label_spent_time), time_entries_path,
            class: "tz-gtab__item #{active_tab == 'timelog' ? 'tz-gtab__item--active' : ''}" %>
    <% end %>
  </div>
</div>
