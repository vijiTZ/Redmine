<%#
  Activity card board partial.
  Uses all existing Redmine helpers unchanged:
    sort_activity_events, format_activity_day, format_activity_title,
    format_activity_description, link_to_user, avatar,
    activity_event_type_icon.
  Events grouped by day, each day rendered as a labelled card grid row.
%>
<div id="activity" class="tz-act-feed">
  <% events_by_day.keys.sort.reverse_each do |day| %>
    <div class="tz-act-day">

      <%# ── Date divider ── %>
      <div class="tz-act-day__header">
        <span class="tz-act-day__label"><%= format_activity_day(day) %></span>
        <span class="tz-act-day__line"></span>
      </div>

      <%# ── Card grid for this day ── %>
      <div class="tz-act-grid">
        <% sort_activity_events(events_by_day[day]).each do |e, in_group| %>

          <div class="tz-act-card <%= "tz-act-card--grouped" if in_group %> <%= (User.current.logged? && e.respond_to?(:event_author) && User.current == e.event_author) ? 'tz-act-card--mine' : '' %>">

            <%# ── Top row: time + event-type badge ── %>
            <div class="tz-act-card__top">
              <span class="tz-act-card__time"><%= format_time(e.event_datetime, false) %></span>
              <span class="tz-act-badge tz-act-badge--<%= e.event_type.to_s.gsub('-','_') %>">
                <%= l("label_#{e.event_type.to_s.gsub('-','_')}_singular",
                      default: e.event_type.to_s.humanize) rescue e.event_type.to_s.humanize %>
              </span>
            </div>

            <%# ── Project name ── %>
            <% if @project.nil? || @project != e.project %>
              <div class="tz-act-card__project"><%= e.project %></div>
            <% end %>

            <%# ── Activity title (main link) ── %>
            <div class="tz-act-card__title">
              <%= link_to format_activity_title(e.event_title), e.event_url,
                    class: 'tz-act-card__link' %>
            </div>

            <%# ── Short description ── %>
            <% desc = format_activity_description(e.event_description) %>
            <% if desc.present? %>
              <p class="tz-act-card__desc"><%= desc %></p>
            <% end %>

            <%# ── Author row ── %>
            <% if e.respond_to?(:event_author) && e.event_author.present? %>
              <div class="tz-act-card__author">
                <span class="tz-act-card__author-label">By</span>
                <span class="tz-act-avatar" aria-hidden="true">
                  <%= e.event_author.name.first(1).upcase %>
                </span>
                <%= link_to_user(e.event_author) %>
              </div>
            <% end %>

          </div><%# /tz-act-card %>

        <% end %>
      </div><%# /tz-act-grid %>

    </div><%# /tz-act-day %>
  <% end %>
</div><%# /tz-act-feed %>
