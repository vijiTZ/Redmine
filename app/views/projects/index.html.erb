<%# Projects index — modern SaaS dashboard layout.
    All Redmine ERB helpers, filters, pagination and permissions are preserved. %>

<div class="tz-pi-page">

  <%# ── Page title ── %>
  <div class="tz-pi-header">
    <h1 class="tz-pi-title"><%= l(:label_project_plural) %></h1>
  </div>

  <%# ── Topbar: shared tab strip (left) + action buttons (right) ── %>
  <div class="tz-pi-topbar">
    <%= render 'shared/project_tabs', active: 'projects' %>

    <div class="tz-pi-actions">
      <%# Redmine's permission-aware action links — kept hidden for logic %>
      <div class="tz-pi-actions__hidden" aria-hidden="true">
        <%= render_project_action_links %>
      </div>

      <%# Visible styled buttons %>
      <% if User.current.allowed_to?(:add_project, nil, global: true) %>
        <%= link_to new_project_path, class: 'tz-pi-btn tz-pi-btn--primary' do %>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none"
               viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path d="M12 5v14M5 12h14"/>
          </svg>
          + <%= l(:label_project_new) %>
        <% end %>
      <% end %>

      <button type="button" class="tz-pi-btn tz-pi-btn--secondary" id="tz-filter-toggle">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none"
             viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/>
        </svg>
        <%= l(:label_filter_plural) %>
      </button>
    </div>
  </div>

  <%# ── Filter form (collapsible) ── %>
  <div class="tz-pi-filter-bar" id="tz-filter-bar">
    <%= form_tag(projects_path, method: :get, id: 'query_form') do %>
      <%= render partial: 'queries/query_form' %>
    <% end %>
  </div>

  <%# ── Project cards grid ── %>
  <% if @query.valid? %>
    <% if @entries.empty? %>
      <div class="tz-pi-empty">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none"
             viewBox="0 0 24 24" stroke="#9ca3af" stroke-width="1.4">
          <rect x="2" y="7" width="20" height="14" rx="2"/>
          <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
        </svg>
        <p><%= l(:label_no_data) %></p>
        <% if User.current.allowed_to?(:add_project, nil, global: true) %>
          <%= link_to new_project_path, class: 'tz-pi-btn tz-pi-btn--primary' do %>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none"
                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path d="M12 5v14M5 12h14"/>
            </svg>
            <%= l(:label_project_new) %>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="tz-pi-grid">
        <% @entries.each do |project| %>
          <% next unless User.current.allowed_to?(:view_project, project) %>
          <div class="tz-pi-card">
            <div class="tz-pi-card__head">
              <%= link_to project.name, project_path(project), class: 'tz-pi-card__name' %>
              <% if project.active? %>
                <span class="tz-pi-badge tz-pi-badge--active"><span class="tz-pi-badge__dot"></span>Active</span>
              <% elsif project.archived? %>
                <span class="tz-pi-badge tz-pi-badge--archived"><span class="tz-pi-badge__dot"></span>Archived</span>
              <% else %>
                <span class="tz-pi-badge tz-pi-badge--closed"><span class="tz-pi-badge__dot"></span>Closed</span>
              <% end %>
            </div>

            <p class="tz-pi-card__desc">
              <%= truncate(strip_tags(project.description.to_s), length: 110, omission: '…') %>
            </p>

            <div class="tz-pi-card__footer">
              <%= link_to l(:label_overview), project_path(project), class: 'tz-pi-card__link' %>
              <% if User.current.allowed_to?(:view_issues, project) %>
                <%= link_to l(:label_issue_plural),
                      project_issues_path(project, set_filter: 1), class: 'tz-pi-card__link' %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%# ── Legend ── %>
  <% if User.current.logged? %>
    <div class="tz-pi-legend">
      <span><%= sprite_icon('user') %>&nbsp;<%= l(:label_my_projects) %></span>
      <span><%= sprite_icon('bookmarked') %>&nbsp;<%= l(:label_my_bookmarks) %></span>
    </div>
  <% end %>

  <%# ── Format links (Atom/CSV) — kept intact ── %>
  <% other_formats_links do |f| %>
    <% if @query.display_type == 'list' %>
      <%= f.link_to_with_query_parameters 'CSV', {},
            onclick: "showModal('csv-export-options', '350px'); return false;" %>
    <% end %>
    <%= f.link_to 'Atom', url: { key: User.current.atom_key } %>
  <% end %>

</div><%# /tz-pi-page %>

<%# ── Filter toggle JS ── %>
<script>
(function () {
  var btn = document.getElementById('tz-filter-toggle');
  var bar = document.getElementById('tz-filter-bar');
  if (!btn || !bar) return;
  btn.addEventListener('click', function () {
    bar.classList.toggle('tz-pi-filter-bar--open');
  });
})();
</script>

<% content_for :sidebar do %>
  <%= render partial: 'projects/sidebar' %>
<% end %>

<% html_title(l(:label_project_plural)) %>
